APP_NAME=digitalgulag
DEBUG=false

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=digitalgulag
POSTGRES_USER=digitalgulag_user
POSTGRES_PASSWORD=change-me

SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# AI Agent
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MOONSHOTAI_API_KEY=
DEFAULT_LLM_MODEL=moonshotai:kimi-k2.5
ENABLE_CRON_GENERATION=false

# Observability (requires `logfire auth` first)
ENABLE_LOGFIRE=false