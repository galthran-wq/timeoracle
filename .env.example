PROJECT_NAME=digitalgulag
COMPOSE_PROJECT_NAME_DEV=${PROJECT_NAME}-dev
COMPOSE_PROJECT_NAME_PROD=${PROJECT_NAME}-prod

POSTGRES_USER=digitalgulag_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=digitalgulag

DEV_POSTGRES_PORT=5444
DEV_NGINX_PORT=5746
PROD_HTTP_PORT=80
PROD_HTTPS_PORT=443

GRAFANA_ADMIN_PASSWORD=change-me
PUBLIC_BASE_URL=https://yourdomain.com

# LangFuse (generate with: openssl rand -hex 32)
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_PASSWORD=changeme

# LangFuse backing services
CLICKHOUSE_PASSWORD=clickhouse
MINIO_ROOT_PASSWORD=minioadmin

